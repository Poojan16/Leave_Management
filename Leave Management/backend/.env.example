# ─── Application ──────────────────────────────────────────────────────────────
ENVIRONMENT=development
# Options: development | staging | production

# ─── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=lms_user
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=leave_management
DATABASE_URL=postgresql+asyncpg://lms_user:change_me_strong_password@postgres:5432/leave_management

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=change_me_redis_password
REDIS_URL=redis://:change_me_redis_password@redis:6379/0

# ─── JWT / Auth ───────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=change_me_generate_with_openssl_rand_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── Email (SendGrid) ─────────────────────────────────────────────────────────
SENDGRID_API_KEY=SG.change_me
FROM_EMAIL=noreply@yourdomain.com
FROM_NAME=Leave Management System

# ─── Monitoring (Sentry) ──────────────────────────────────────────────────────
# Leave empty to disable Sentry
SENTRY_DSN=

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
AUTH_RATE_LIMIT_PER_MINUTE=10
